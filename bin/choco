#!/usr/bin/env php
<?php
require_once __DIR__ . '/../vendor/autoload.php';

use Dotenv\Dotenv;
use Symfony\Component\Console\Application;

$dotenv = Dotenv::createImmutable(__DIR__ . '/../');
$dotenv->load();

$app = new Application('ChocoPHP CLI', '1.0.0');

$app->add(new Choco\Console\ServeCommand());
$app->add(new Choco\Console\ControllerCommand());
$app->add(new Choco\Console\MigrationCommand());

$app->run();